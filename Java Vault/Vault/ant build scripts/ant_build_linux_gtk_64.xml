<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<project default="create_run_jar" name="Create Runnable Jar for Project Vault">
    <!--ANT 1.7 is required                                        -->
    <target name="create_run_jar">
    	<property name="deployroot" location="c:/temp/Vault3" />
        <property name="sourcerootCommonCode" location="../../../CommonCode" />
        <property name="sourcerootVault" location=".." />
    	<property name="projectroot" location="../../.." />
    	<property name="dest.dir" location="${deployroot}/Vault3LinuxGTK64" />
    	<property name="zipfile" location="${deployroot}/Vault3LinuxGTK64.zip" />
    	<delete file="${zipfile}" />
    	<delete dir="${dest.dir}"/>
    	<mkdir dir="${dest.dir}" />
        <jar destfile="${dest.dir}/vault_linux_gtk.jar" filesetmanifest="mergewithoutmain">
            <manifest>
                <attribute name="Built-By" value="${user.name}"/>
                <attribute name="Main-Class" value="mainPackage.MainApplicationWindow"/>
                <attribute name="Class-Path" value="."/>
            </manifest>
            <fileset dir="${sourcerootVault}/bin"/>
            <fileset dir="${sourcerootCommonCode}/bin"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\swt-4.23-gtk-linux-x86_64\swt.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.core.commands_3.10.100.v20210722-1426.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.core.runtime_3.24.100.v20220211-2001.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.equinox.common_3.16.0.v20220211-2322.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.jface.text_3.20.0.v20220218-1549.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.jface_3.25.0.v20220218-1636.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.osgi_3.17.200.v20220215-2237.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Eclipse 4.23\eclipse-platform-4.23-linux-gtk-x86_64\eclipse\plugins\org.eclipse.text_3.12.0.v20210512-1644.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:/Program Files/javamail-1.4.4/mail.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:/Program Files/imgscalr-lib-4.2/imgscalr-lib-4.2.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Program Files\sqlite4java-392\sqlite4java.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:/Program Files/perf4j/perf4j-0.9.16.jar"/>
            <zipfileset excludes="META-INF/*.SF" src="C:\Program Files\itext-5.2.1\itextpdf-5.2.1.jar"/>
        </jar>
    	<copy todir="${dest.dir}" failonerror="true">
    		<fileset file="${sourcerootVault}/example.vl3" />
    		<fileset file="${sourcerootVault}/LicenseTerms.txt" />
    		<fileset file="C:/Program Files/sqlite4java-392/libsqlite4java-linux-amd64.so" />
    		<fileset file="${sourcerootVault}/src/mainPackage/artwork/vault3.png" />
    	</copy>
    	<copy todir="${dest.dir}/Help" failonerror="true">
    		<fileset dir="${sourcerootVault}/Help" />
    	</copy>
    	<zip destfile="${zipfile}">
    		<fileset dir="${dest.dir}" />
    	</zip>
    </target>
</project>
